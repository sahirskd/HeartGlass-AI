# Ignore python cache files
__pycache__/
*.py[cod]
*$py.class

# Ignore virtual environments
.venv/
venv/
ENV/
env.bak/
venv.bak/

# Ignore frontend directory (will have its own Dockerfile if needed)
frontend/

# Ignore Jupyter notebooks and datasets
dataset/
*.ipynb
.ipynb_checkpoints/

# Ignore logs
*.log

# Ignore git and dvc metadata within the container
.git/
.dvc/
.dvcignore
